<Window x:Class="EnvVarManager.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="环境变量管理器"
        Height="720"
        MinHeight="620"
        Width="1120"
        MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="#F4F6F8"
        FontFamily="Microsoft YaHei UI, Segoe UI">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8" />
        <SolidColorBrush x:Key="DangerBrush" Color="#D14343" />
        <SolidColorBrush x:Key="TextBrush" Color="#172033" />
        <SolidColorBrush x:Key="MutedBrush" Color="#697386" />
        <SolidColorBrush x:Key="LineBrush" Color="#E1E6EF" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CED6E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="BorderBrush" Value="#CED6E3" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="MinWidth" Value="96" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource AccentHoverBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.52" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#CAD3E1" />
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
            <Setter Property="BorderBrush" Value="#E8B4B4" />
        </Style>

        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="#FFFFFF"
                                BorderBrush="#E4E9F2"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#B9C8DD" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF5FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="环境变量管理器"
                           FontSize="28"
                           FontWeight="SemiBold" />
                <TextBlock Text="管理当前 Windows 用户级环境变量。保存后请重新打开终端、IDE 或 Codex，让新进程读取最新值。"
                           Margin="0,6,0,0"
                           Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="刷新"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,8,0" />
                <Button Content="复制变量名"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding CopyNameCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="390" />
                    <ColumnDefinition Width="1" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="变量列表" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="常见 API key 已预置，也可以添加你自己的变量名。"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,14,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Text="搜索"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,0,0,6" />
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Grid.Row="1"
                                 ToolTip="按变量名、服务名、类别、已设置或未设置搜索" />
                        <TextBlock Grid.Row="2"
                                   Text="添加自定义变量"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="0,12,0,6" />
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{Binding CustomName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="例如 MY_SERVICE_API_KEY" />
                            <Button Grid.Column="2"
                                    Content="添加"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding AddCustomCommand}" />
                        </Grid>
                    </Grid>

                    <ListBox Grid.Row="2"
                             ItemsSource="{Binding EntriesView}"
                             SelectedItem="{Binding SelectedEntry, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14" />
                                        <TextBlock Text="{Binding DisplayName}"
                                                   Foreground="{StaticResource MutedBrush}"
                                                   Margin="0,3,0,0" />
                                        <TextBlock Text="{Binding MaskedValue}"
                                                   Foreground="#44546A"
                                                   FontFamily="Consolas"
                                                   Margin="0,6,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1"
                                            Height="24"
                                            MinWidth="58"
                                            Padding="9,2"
                                            VerticalAlignment="Top"
                                            CornerRadius="12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#F2F4F8" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSet}" Value="True">
                                                        <Setter Property="Background" Value="#E8F7EF" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding StatusText}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#697386" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSet}" Value="True">
                                                            <Setter Property="Foreground" Value="#197A4D" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <Border Grid.Column="1" Background="{StaticResource LineBrush}" />

                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <Grid Margin="26">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Text="{Binding SelectedEntry.DisplayName}"
                                       FontSize="24"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedEntry.Description}"
                                       Margin="0,6,0,0"
                                       Foreground="{StaticResource MutedBrush}" />
                        </StackPanel>

                        <UniformGrid Grid.Row="1" Columns="2" Margin="0,24,0,18">
                            <Border Background="#F7F9FC" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,10,0">
                                <StackPanel>
                                    <TextBlock Text="变量名" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding SelectedEntry.Name}" FontFamily="Consolas" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                            <Border Background="#F7F9FC" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="10,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="当前状态" Foreground="{StaticResource MutedBrush}" />
                                    <TextBlock Text="{Binding SelectedEntry.DetailText}" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <Border Grid.Row="2"
                                Background="#F7F9FC"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18"
                                Margin="0,0,0,18">
                            <StackPanel>
                                <TextBlock Text="当前值" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="默认只显示脱敏值；需要确认或复制时再查看完整内容。"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,5,0,14" />
                                <TextBox Text="{Binding CurrentValueText, Mode=OneWay}"
                                         IsReadOnly="True"
                                         Height="72"
                                         FontFamily="Consolas"
                                         TextWrapping="Wrap"
                                         VerticalScrollBarVisibility="Auto"
                                         VerticalContentAlignment="Top"
                                         ToolTip="当前用户级环境变量的值" />
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="{Binding RevealCurrentValueButtonText}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ToggleRevealCurrentValueCommand}" />
                                    <Button Grid.Column="2"
                                            Content="复制当前值"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding CopyCurrentValueCommand}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3"
                                Background="#FAFBFD"
                                BorderBrush="{StaticResource LineBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="18">
                            <StackPanel>
                                <TextBlock Text="设置新值" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="这里不会展示完整旧值。输入新值并保存即可覆盖；不想保留该变量时使用删除。"
                                           Foreground="{StaticResource MutedBrush}"
                                           Margin="0,5,0,14" />
                                <PasswordBox x:Name="SecretValueBox"
                                             PasswordChanged="SecretValueBox_OnPasswordChanged"
                                             ToolTip="输入新的 API key 或 token" />
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Content="保存新值"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            Command="{Binding SaveCommand}" />
                                    <Button Grid.Column="2"
                                            Content="删除变量"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Command="{Binding DeleteCommand}" />
                                    <Button Grid.Column="4"
                                            Content="清空输入"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="ClearSecretValue_OnClick" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4"
                                Margin="0,18,0,0"
                                Background="#FFF9E8"
                                BorderBrush="#EAC86A"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="14">
                            <TextBlock Foreground="#6A4C00"
                                       Text="提示：这个工具只管理“当前用户”的环境变量，不会修改系统级变量。已经打开的终端、IDE、Codex 进程通常不会自动刷新，请重新打开后再运行脚本。" />
                        </Border>
                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="#FFFFFF"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12"
                Margin="0,14,0,0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" />
        </Border>
    </Grid>
</Window>
